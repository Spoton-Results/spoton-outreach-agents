{
  "name": "subdraw-agents",
  "version": "2.0.0",
  "description": "18-agent autonomous outreach system for SubDraw — construction draw management SaaS",
  "main": "scripts/run-pipeline.js",
  "scripts": {
    "swarm": "node scripts/run-pipeline.js",
    "prospect": "node scripts/run-pipeline.js --mode prospect",
    "replies": "node scripts/run-pipeline.js --mode replies",
    "monitor": "node scripts/run-pipeline.js --mode monitor",
    "score": "node scripts/run-pipeline.js --mode score",
    "texas": "node scripts/run-pipeline.js --mode prospect --state Texas",
    "florida": "node scripts/run-pipeline.js --mode prospect --state Florida",
    "arizona": "node scripts/run-pipeline.js --mode prospect --state Arizona",
    "start:prospector": "node scripts/run-prospector.js",
    "start:continuous": "node scripts/prospector-continuous.js"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "node-fetch": "^3.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}